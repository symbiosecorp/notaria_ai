# Copia este archivo a .env.local y llena los valores reales.
# NUNCA commitees claves reales; .env.local está gitignored (regla *.local).
# Toda variable nueva se documenta aquí SIN valor.

# TanStack AI — proveedor Anthropic
ANTHROPIC_API_KEY=

# Supabase — la publishable key es segura para el cliente; la service_role/secret key JAMÁS.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Solo servidor (TanStack Start server functions). Sin prefijo VITE_ — no va al bundle cliente.
SUPABASE_SERVICE_ROLE_KEY=
